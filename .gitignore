# Изолированные данные по cookie-сессии браузера
user_data/

# Конфигурация и секреты (не публиковать в репозитории)
config.json
cookies.json
settings.json
custom_templates.json
.env
.env.local
*.env

# Render (Blueprint не в репозитории — настройки только в панели Render)
render.yaml

# Аккаунты (токены, прокси)
accounts/*.json
!accounts/.gitkeep

# Логи и аналитика (генерируются при работе)
logs/*.log
!logs/.gitkeep
analytics.json

# Временные и служебные файлы
temp_template.txt
page_source.html
*.pyc
__pycache__/
*.pyo
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# Виртуальное окружение
venv/
.venv/
env/
ENV/

# IDE и ОС
.idea/
.vscode/
.cursor/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

